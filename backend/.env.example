# AI provider: local (default, no key required), claude, openai
ANALYSIS_PROVIDER=local

# Optional — only needed when ANALYSIS_PROVIDER=claude
# ANTHROPIC_API_KEY=

# Optional — only needed when ANALYSIS_PROVIDER=openai
# OPENAI_API_KEY=

# Optional — override the default model for the selected cloud provider
# claude default: claude-sonnet-4-6   openai default: gpt-4o
# AI_MODEL=

# Future persistence settings
# DATABASE_URL=
