# ---------------------------------------------------------------------------
# How to activate a cloud provider locally
# ---------------------------------------------------------------------------
# 1. Copy this file:  cp backend/.env.example backend/.env
# 2. Set the provider: ANALYSIS_PROVIDER=claude
# 3. Set your key:     ANTHROPIC_API_KEY=sk-ant-...
# backend/.env is gitignored — never commit real keys.
# Leave ANALYSIS_PROVIDER=local (the default) to run entirely on-device.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# AI provider
# ---------------------------------------------------------------------------
# local   — default; all analysis runs on-device, no key needed, no data sent out.
# claude  — sends retrieved document fragments to the Anthropic API.
# openai  — sends retrieved document fragments to the OpenAI API.
#
# PRIVACY: enabling a cloud provider transmits document text to a third-party
# service. Do NOT use a cloud provider with real sensitive or confidential
# contracts unless all relevant parties have consented and you have reviewed
# the provider's data-handling and retention terms.
# ---------------------------------------------------------------------------
ANALYSIS_PROVIDER=local

# Required when ANALYSIS_PROVIDER=claude  (never commit a real key)
# ANTHROPIC_API_KEY=

# Required when ANALYSIS_PROVIDER=openai  (never commit a real key)
# OPENAI_API_KEY=
# Note: openai==2.41.1 is in requirements.txt; SDK calls are fully wired.

# Optional — override the default model for the selected cloud provider
# claude default: claude-sonnet-4-6   openai default: gpt-4o
# AI_MODEL=

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# AUTH_SECRET is used to sign JWTs issued by POST /auth/login and /auth/register.
# The backend falls back to a hardcoded dev placeholder when this is not set.
# NEVER use the default placeholder in production — generate a real secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
# AUTH_SECRET=

# ---------------------------------------------------------------------------
# Storage backend
# ---------------------------------------------------------------------------
# json      — default; documents stored in data/documents.json (no setup required)
# postgres  — PostgresDocumentRepository via psycopg2; requires DATABASE_URL below
#             Core document lifecycle (create/list/get/delete) is implemented.
#             Unimplemented operations raise NotImplementedError at call time.
# STORAGE_BACKEND=json

# ---------------------------------------------------------------------------
# Database  (required when STORAGE_BACKEND=postgres)
# ---------------------------------------------------------------------------
# The Docker Compose db service (pgvector/pgvector:pg16) applies db/schema.sql
# automatically on first start.
#   DB_PASSWORD defaults to luminaclause_dev (LOCAL DEVELOPMENT ONLY).
#   Override:  DB_PASSWORD=<strong-secret> docker compose up
#
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
#
# Docker Compose — backend reaches db via the internal container hostname:
# DATABASE_URL=postgresql://luminaclause:luminaclause_dev@db:5432/luminaclause
#
# Local psql outside Docker:
# DATABASE_URL=postgresql://luminaclause:luminaclause_dev@localhost:5432/luminaclause

# ---------------------------------------------------------------------------
# Integration tests  (optional — never point at a production database)
# ---------------------------------------------------------------------------
# Set TEST_DATABASE_URL to run the PostgreSQL integration tests.
# This variable is intentionally separate from DATABASE_URL so that
# tests cannot accidentally connect to a production or staging database.
# TEST_DATABASE_URL=postgresql://luminaclause:luminaclause_dev@localhost:5432/luminaclause_test
