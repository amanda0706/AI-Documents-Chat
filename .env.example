NEXT_PUBLIC_API_URL=http://localhost:8000

# AI provider: local (default, no key required), claude, openai
ANALYSIS_PROVIDER=local

# Optional — only needed when ANALYSIS_PROVIDER=claude
# ANTHROPIC_API_KEY=

# Optional — only needed when ANALYSIS_PROVIDER=openai
# OPENAI_API_KEY=

# Optional — override the default model for the selected provider
# AI_MODEL=
